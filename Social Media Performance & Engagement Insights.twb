      <aliases enabled='yes' />
      <column caption='Total Engagement' datatype='integer' name='[Calculation_2963087118641750016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[likes] + [comments] + [shares]' />
      </column>
      <column caption='Engagement Rate Recalc' datatype='real' name='[Calculation_2963087118641905665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [views] &gt; 0 THEN&#13;&#10;    ([likes] + [comments] + [shares]) / [views]&#13;&#10;ELSE 0 END' />
      </column>
      <column caption='Weighted Engagement' datatype='integer' name='[Calculation_2963087118641995778]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([likes] * 1) +&#13;&#10;([comments] * 2) +&#13;&#10;([shares] * 3)' />
      </column>
      <column caption='Engagement Quality' datatype='real' name='[Calculation_2963087118642073603]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [views] &gt; 0 THEN&#13;&#10;    [Calculation_2963087118641995778] / [views]&#13;&#10;ELSE 0 END' />
      </column>
      <column caption='Hour' datatype='integer' name='[Calculation_2963087118642282500]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [post_datetime])' />
      </column>
      <column caption='Day of Week' datatype='string' name='[Calculation_2963087118642352133]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [post_datetime])' />
      </column>
      <column caption='Avg Engagement Rate' datatype='real' name='[Calculation_2963087118882115590]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Engagement]) / SUM([views])' />
      </column>
      <column caption='social_media_performance_dashboard.csv' datatype='table' name='[__tableau_internal_object_id__].[social_media_performance_dashboard.csv_68F67EDA4E0748408C382FFB762D0300]' role='measure' type='quantitative' />
